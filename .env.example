# .env.example — Canonical list of required environment variables
# Copy to .env.local and fill in values:  cp .env.example .env.local
#
# Required vars are marked [REQUIRED]. Others are optional or have defaults.

# --- Database ---
DATABASE_URL=              # [REQUIRED] Neon pooled connection string (or local postgres)
# DIRECT_URL=              # Neon direct connection (for migrations only)

# --- Auth ---
NEXTAUTH_SECRET=           # [REQUIRED] Random secret for NextAuth.js session encryption
NEXTAUTH_URL=              # [REQUIRED] App base URL (http://localhost:3000 for local dev)

# --- Google ---
GOOGLE_PLACES_API_KEY=     # [REQUIRED] Google Places API key (server-side)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # [REQUIRED] Google Maps JS API key (client-side)
# GOOGLE_PLACES_ENABLED=   # Set to 'false' to disable Google Places calls

# --- AI / LLM ---
# ANTHROPIC_API_KEY=       # Anthropic API key (for SKAI features)
# AI_MODEL=                # Override default AI model

# --- Email ---
# RESEND_API_KEY=          # Resend API key (for transactional email)
# RESEND_FROM_EMAIL=       # Sender email address

# --- Storage (Cloudflare R2) ---
# R2_ACCESS_KEY_ID=        # R2 access key
# R2_SECRET_ACCESS_KEY=    # R2 secret key
# R2_ENDPOINT=             # R2 endpoint URL
# R2_BUCKET_NAME=          # R2 bucket name

# --- Cache (Upstash Redis) ---
# UPSTASH_REDIS_REST_URL=  # Upstash Redis REST URL
# UPSTASH_REDIS_REST_TOKEN=# Upstash Redis REST token

# --- App ---
NEXT_PUBLIC_APP_URL=       # [REQUIRED] Public app URL (http://localhost:3000 for local dev)
# NEXT_PUBLIC_APP_NAME=    # App display name (defaults to "Saiko")
# ADMIN_EMAILS=            # Comma-separated admin email addresses

# --- Debug (dev only) ---
# ADMIN_DEBUG=true         # Enable admin debug endpoints
# AUTH_DEBUG=true          # Enable auth debug logging
# DEBUG_HEADERS=1          # Log API response headers
# DEBUG_INSTAGRAM=1        # Log Instagram API calls

# --- Vercel (set automatically in Vercel environments) ---
# VERCEL_ENV=              # 'production', 'preview', or 'development'
# VERCEL_URL=              # Deployment URL (set by Vercel)
# VERCEL_GIT_COMMIT_SHA=   # Git commit SHA (set by Vercel)
