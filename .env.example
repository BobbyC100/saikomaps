# =============================================================================
# Saiko Maps — Environment Variable Reference
# =============================================================================
# Copy secrets to .env.local (gitignored). Non-sensitive defaults live in .env.
# Production secrets live in Vercel Environment Variables dashboard.
# =============================================================================

# Database (Neon PostgreSQL — use the pooler endpoint)
DATABASE_URL=              # postgresql://user:pass@host-pooler.region.neon.tech/db?sslmode=require
DB_ENV=dev                 # dev | prod

# Auth (NextAuth)
NEXTAUTH_SECRET=           # Generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAILS=              # Comma-separated: admin@example.com

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=         # From: https://console.anthropic.com/

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=    # From: https://console.upstash.com/
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=               # https://<account>.r2.cloudflarestorage.com
R2_BUCKET_NAME=saiko-assets

# Google
GOOGLE_PLACES_API_KEY=     # Backend-only Places API key
GOOGLE_PLACES_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=    # For Google Docs sync
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DOCS_ROOT_FOLDER_ID=

# Instagram (Graph API)
INSTAGRAM_ACCESS_TOKEN=    # Long-lived page token
INSTAGRAM_USER_ID=         # Business account ID

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=    # From: https://sentry.io/settings/
SENTRY_DSN=                # Same value (server-side)
# SENTRY_AUTH_TOKEN=       # Optional: enables source map uploads

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Debug (uncomment to enable verbose auth logging locally)
# AUTH_DEBUG=true
# DEBUG_ROUTES_ENABLED=true
