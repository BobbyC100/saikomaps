generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_spots {
  id          String     @id
  name        String
  slug        String?    @unique
  latitude    Float
  longitude   Float
  layerType   LayerType  @map("layer_type")
  city        String?
  region      String?
  country     String     @default("US")
  spotType    String?    @map("spot_type")
  tags        String[]
  surface     String?
  skillLevel  String?    @map("skill_level")
  exposure    String?
  description String?
  seasonality String?
  isPublic    Boolean    @default(true) @map("is_public")
  source      SpotSource
  sourceId    String?    @map("source_id")
  sourceUrl   String?    @map("source_url")
  verified    Boolean    @default(false)
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @map("updated_at")

  @@index([layerType, city])
  @@index([layerType, latitude, longitude])
  @@index([source, sourceId])
}

model import_jobs {
  id                 String    @id
  userId             String    @map("user_id")
  listId             String?   @map("list_id")
  status             String    @default("processing")
  totalLocations     Int?      @map("total_locations")
  processedLocations Int       @default(0) @map("processed_locations")
  failedLocations    Int       @default(0) @map("failed_locations")
  errorLog           Json?     @map("error_log")
  createdAt          DateTime  @default(now()) @map("created_at")
  completedAt        DateTime? @map("completed_at")
  lists              lists?    @relation(fields: [listId], references: [id])
  users              users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model lists {
  id                  String           @id
  userId              String           @map("user_id")
  title               String
  subtitle            String?
  description         String?
  descriptionSource   String?          @map("description_source")
  slug                String           @unique
  introText           String?          @map("intro_text")
  functionType        String?          @map("function_type")
  functionContext     String?          @map("function_context")
  scopeGeography      String?          @map("scope_geography")
  scopePlaceTypes     String[]         @map("scope_place_types")
  scopeExclusions     String[]         @map("scope_exclusions")
  organizingLogic     OrganizingLogic? @map("organizing_logic")
  organizingLogicNote String?          @map("organizing_logic_note")
  notes               String?
  status              MapStatus        @default(DRAFT)
  publishedAt         DateTime?        @map("published_at")
  templateType        String           @default("field-notes") @map("template_type")
  coverImageUrl       String?          @map("cover_image_url")
  primaryColor        String           @default("#5BA7A7") @map("primary_color")
  secondaryColor      String           @default("#7FA5A5") @map("secondary_color")
  accessLevel         String           @default("public") @map("access_level")
  passwordHash        String?          @map("password_hash")
  allowedEmails       String[]         @map("allowed_emails")
  published           Boolean          @default(false)
  viewCount           Int              @default(0) @map("view_count")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @map("updated_at")
  import_jobs         import_jobs[]
  users               users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations           locations[]
  map_places          map_places[]
  saved_maps          saved_maps[]

  @@index([published])
  @@index([slug])
  @@index([status])
  @@index([userId])
}

model locations {
  id                 String    @id
  listId             String    @map("list_id")
  googlePlaceId      String?   @map("google_place_id")
  name               String
  address            String?
  latitude           Decimal?  @db.Decimal(10, 8)
  longitude          Decimal?  @db.Decimal(11, 8)
  phone              String?
  website            String?
  instagram          String?
  tiktok             String?
  hours              Json?
  description        String?
  googleTypes        String[]  @default([]) @map("google_types")
  priceLevel         Int?      @map("price_level")
  neighborhood       String?
  googlePhotos       Json?     @map("google_photos")
  userPhotos         String[]  @map("user_photos")
  userNote           String?   @map("user_note")
  category           String?
  descriptor         String?
  orderIndex         Int       @default(0) @map("order_index")
  placesDataCachedAt DateTime? @map("places_data_cached_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @map("updated_at")
  lists              lists     @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([googlePlaceId])
  @@index([listId, category])
  @@index([listId])
  @@index([listId, orderIndex])
}

model map_places {
  id         String   @id
  mapId      String   @map("map_id")
  entityId   String   @map("entity_id")
  descriptor String?  @db.VarChar(120)
  userNote   String?  @map("user_note")
  userPhotos String[] @map("user_photos")
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @map("updated_at")
  lists      lists    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  entities   entities @relation(fields: [entityId], references: [id])

  @@unique([mapId, entityId])
  @@index([mapId])
  @@index([mapId, orderIndex])
  @@index([entityId])
}

model categories {
  id        String  @id @default(cuid())
  slug      String  @unique
  label     String
  isActive  Boolean @default(true) @map("is_active")

  entities entities[]
}

model people {
  id                  String             @id
  name                String
  slug                String             @unique
  role                PersonRole
  visibility          Visibility
  bio                 String?
  imageUrl            String?            @map("image_url")
  sources             Json
  restaurantGroupId   String?            @map("restaurant_group_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @map("updated_at")
  restaurant_groups   restaurant_groups? @relation(fields: [restaurantGroupId], references: [id])
  person_places       person_places[]

  @@index([restaurantGroupId])
  @@index([slug])
  @@index([visibility])
}

model person_places {
  id         String          @id
  personId   String          @map("person_id")
  entityId   String          @map("entity_id")
  role       PersonPlaceRole
  current    Boolean         @default(true)
  startYear  Int?            @map("start_year")
  endYear    Int?            @map("end_year")
  source     String
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @map("updated_at")
  people     people          @relation(fields: [personId], references: [id], onDelete: Cascade)
  entities   entities        @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([personId, entityId, role])
  @@index([current])
  @@index([personId])
  @@index([entityId])
}

model entities {
  id                     String             @id
  slug                   String             @unique
  googlePlaceId          String?            @unique @map("google_place_id")
  name                   String
  address                String?
  latitude               Decimal?           @db.Decimal(10, 8)
  longitude              Decimal?           @db.Decimal(11, 8)
  phone                  String?
  website                String?
  instagram              String?
  tiktok                 String?
  hours                  Json?
  description            String?
  googlePhotos           Json?              @map("google_photos")
  googleTypes            String[]           @default([]) @map("google_types")
  priceLevel             Int?               @map("price_level")
  neighborhood           String?
  category               String?
  primaryVertical        PrimaryVertical     @map("primary_vertical")
  placesDataCachedAt     DateTime?           @map("places_data_cached_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  editorialSources       Json?              @map("editorial_sources")
  cuisineType            String?            @map("cuisine_type")
  adUnitOverride         Boolean            @default(false) @map("ad_unit_override")
  adUnitType             String?            @map("ad_unit_type")
  pullQuote              String?            @map("pull_quote")
  pullQuoteAuthor        String?            @map("pull_quote_author")
  pullQuoteSource        String?            @map("pull_quote_source")
  pullQuoteType          String?            @map("pull_quote_type")
  pullQuoteUrl           String?            @map("pull_quote_url")
  tagline                String?
  taglineCandidates      String[]           @default([]) @map("tagline_candidates")
  taglineGenerated       DateTime?          @map("tagline_generated")
  taglinePattern         String?            @map("tagline_pattern")
  taglineSignals         Json?              @map("tagline_signals")
  tips                   String[]           @default([])
  transitAccessible      Boolean?           @map("transit_accessible")
  thematicTags           String[]           @default([]) @map("thematic_tags")
  contextualConnection   String?            @map("contextual_connection")
  curatorAttribution     String?            @map("curator_attribution")
  chefRecs               Json?              @map("chef_recs")
  restaurantGroupId      String?            @map("restaurant_group_id") // DEPRECATED: use place_actor_relationships. No new writes.
  status                 PlaceStatus        @default(OPEN)
  // Entity State Model v1 — three independent axes (nullable during migration)
  operatingStatus        OperatingStatus?   @map("operating_status")
  enrichmentStatus       EnrichmentStatus?  @map("enrichment_status")
  publicationStatus      PublicationStatus?  @map("publication_status")
  intentProfile          String?            @map("intent_profile")
  intentProfileOverride  Boolean            @default(false) @map("intent_profile_override")
  reservationUrl         String?            @map("reservation_url")
  businessStatus         String?            @map("business_status") // from Google; 'CLOSED_PERMANENTLY' excluded from coverage
  googlePlacesAttributes Json?              @map("google_places_attributes")
  entityType             PlaceType          @default(venue) @map("entity_type")
  categoryId             String?            @map("category_id")
  parentId               String?            @map("parent_id")
  marketSchedule         Json?              @map("market_schedule")
  // Entity Dimension Model v1 — four classification dimensions (ARCH-ENTITY-CLASSIFICATION-FRAMEWORK-V1)
  // All nullable: null = unmigrated, not broken. Patterns are derived from dimension combinations.
  locationType           LocationType?      @map("location_type")
  scheduleType           ScheduleType?      @map("schedule_type")
  identityAnchorType     IdentityAnchorType? @map("identity_anchor_type")
  containmentType        ContainmentType?   @map("containment_type")
  prlOverride            Int?               @map("prl_override") // 1-4 manual override; display PRL = override ?? computed
  map_places             map_places[]
  person_places          person_places[]
  restaurant_groups      restaurant_groups? @relation(fields: [restaurantGroupId], references: [id])
  category_rel           categories?        @relation(fields: [categoryId], references: [id])
  parent                 entities?          @relation("PlaceHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children               entities[]         @relation("PlaceHierarchy")
  viewer_bookmarks       viewer_bookmarks[]
  energy_scores          energy_scores[]
  entityActorRelationships EntityActorRelationship[]
  place_tag_scores       place_tag_scores[]
  place_photo_eval       place_photo_eval[]
  place_photos           place_photos[]
  place_coverage_status  place_coverage_status[]
  gpid_resolution_queue   gpid_resolution_queue[]
  place_actor_relationships PlaceActorRelationship[]
  park_children  ParkFacilityRelationship[] @relation("park_parent")
  park_parents   ParkFacilityRelationship[] @relation("park_child")
  operatorPlaceCandidates OperatorPlaceCandidate[]
  place_appearances_as_subject place_appearances[] @relation("AppearanceSubject")
  place_appearances_as_host    place_appearances[] @relation("AppearanceHost")

  // Confidence System v1: field-level JSONB, computed at sync (not at query time)
  confidence           Json?    // { field: { value, score, sources, winner, conflicts } }
  overallConfidence   Float?   @default(0.5) @map("overall_confidence")
  confidenceUpdatedAt DateTime? @map("confidence_updated_at")

  // Description enrichment metadata
  descriptionSource     String?  @map("description_source")     // editorial | website | google_editorial | synthesis
  descriptionConfidence Float?   @map("description_confidence") // 0.0–1.0
  descriptionReviewed   Boolean  @default(false) @map("description_reviewed")

  // Website enrichment (SAIKO spec v1.1)
  lastEnrichedAt   DateTime? @map("last_enriched_at")
  enrichmentStage  String?   @map("enrichment_stage") // e.g. ENRICHED_WEBSITE
  needsHumanReview Boolean  @default(false) @map("needs_human_review")
  categoryEnrichAttemptedAt DateTime? @map("category_enrich_attempted_at") // throttle category-only re-enrich

  merchant_enrichment_runs merchant_enrichment_runs[]
  merchant_signals         merchant_signals?
  coverage_sources              coverage_sources[]
  coverage_source_extractions   coverage_source_extractions[]
  surface_scans                 merchant_surface_scans[]
  merchant_surfaces        merchant_surfaces[]
  menu_fetches             menu_fetches[]

  // Fields v2 relations
  canonical_state       canonical_entity_state?
  entity_claims         observed_claims[]
  derived_signals       derived_signals[]
  interpretation_cache  interpretation_cache[]
  fieldsMemberships     FieldsMembership[]
  traceSignalsCache     TraceSignalsCache?

  // Instagram ingestion
  instagram_accounts    instagram_accounts[]

  // Coverage Operations
  entity_issues         entity_issues[]

  // Reservation Provider Validation
  reservation_provider_matches reservation_provider_matches[]

  @@map("entities")
  @@index([category])
  @@index([categoryId])
  @@index([googlePlaceId])
  @@index([neighborhood])
  @@index([primaryVertical])
  @@index([parentId])
  @@index([restaurantGroupId])
  @@index([status])
  @@index([businessStatus])
  @@index([lastEnrichedAt])
  @@index([needsHumanReview])
}

/// Website enrichment runs — append-only audit (SAIKO spec v1.1)
model merchant_enrichment_runs {
  id              String    @id @default(uuid())
  entityId        String    @map("entity_id")
  sourceUrl       String    @map("source_url")
  finalUrl        String?   @map("final_url")
  fetchedAt       DateTime  @default(now()) @map("fetched_at")
  httpStatus      Int?      @map("http_status")
  extractionJson  Json      @default("{}") @map("extraction_json")
  confidence      Decimal?  @db.Decimal(4, 2)
  costUsd         Decimal   @default(0) @map("cost_usd") @db.Decimal(10, 6)
  createdAt       DateTime  @default(now()) @map("created_at")

  entities entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([fetchedAt])
}

/// Menu fetch records — append-only, one row per fetch attempt per entity.
/// raw_text is stored directly. Full HTML is stored in R2 and referenced via raw_html_pointer.
/// Current-state is derived as the latest successful fetch (http_status < 400) per entity.
model menu_fetches {
  id                    String   @id @default(uuid())
  entityId              String   @map("entity_id")
  sourceUrl             String   @map("source_url")
  finalUrl              String?  @map("final_url")
  menuFormat            String   @default("html") @map("menu_format")       // html | pdf | external
  httpStatus            Int?     @map("http_status")
  contentType           String?  @map("content_type")                       // actual HTTP content-type of fetched response
  fetchDurationMs       Int?     @map("fetch_duration_ms")
  fetchedAt             DateTime @default(now()) @map("fetched_at")
  rawText               String?  @map("raw_text")
  contentHash           String?  @map("content_hash")                       // sha256(raw_text)
  rawHtmlPointer        String?  @map("raw_html_pointer")                   // r2://bucket/...  (HTML or PDF receipt)
  textExtractionMethod  String?  @map("text_extraction_method")             // node-html-parser-v1 | pdftotext
  pdfType               String?  @map("pdf_type")                           // text_based | image_based | unknown
  extractionQuality     String?  @map("extraction_quality")                 // good | sparse | empty
  createdAt             DateTime @default(now()) @map("created_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([fetchedAt])
  @@index([contentHash])
  @@index([extractionQuality])
  @@map("menu_fetches")
}

/// Merchant surfaces — immutable evidence layer.
/// One row per capture event per surface URL. Never updated.
/// Current state for a URL = latest row ordered by discovered_at.
///
/// fetch_status:      discovered | fetch_success | fetch_failed
/// parse_status:      parse_pending | parse_success | parse_failed
/// extraction_status: not_attempted | extracted | no_signals
///
/// surface_type:      homepage | about | menu | drinks | instagram | reservation | ordering | contact
///
/// Immutability is enforced by a DB trigger (see migration 20260308000000).
/// Never call prisma.merchant_surfaces.update() — create new rows instead.
model merchant_surfaces {
  id                String    @id @default(uuid())
  entityId          String    @map("entity_id")

  surfaceType       String    @map("surface_type")
  sourceUrl         String    @map("source_url")

  contentType       String?   @map("content_type")    // html | pdf | json | unknown

  fetchStatus       String    @map("fetch_status")     // discovered | fetch_success | fetch_failed
  parseStatus       String?   @map("parse_status")     // parse_pending | parse_success | parse_failed
  extractionStatus  String    @default("not_attempted") @map("extraction_status") // not_attempted | extracted | no_signals

  contentHash       String?   @map("content_hash")     // sha256(raw_text)
  rawText           String?   @map("raw_text")          // stripped text content
  rawHtml           String?   @map("raw_html")          // full HTML (large; future: R2 pointer)

  fetchedAt         DateTime? @map("fetched_at")        // null for fetch_status='discovered'
  discoveredAt      DateTime  @default(now()) @map("discovered_at")

  metadataJson      Json?     @map("metadata_json")     // http_status, final_url, fetch_duration_ms, discovered_from_id, link_text

  entity    entities                     @relation(fields: [entityId], references: [id], onDelete: Cascade)
  artifacts merchant_surface_artifacts[]

  @@index([entityId])
  @@index([entityId, surfaceType])
  @@index([surfaceType, fetchStatus])
  @@index([fetchStatus, parseStatus])        // replay queries
  @@index([surfaceType, extractionStatus])   // extraction targeting
  @@index([contentHash])
  @@index([discoveredAt])
  @@map("merchant_surfaces")
}

/// Parse artifacts derived from merchant surface HTML.
/// One row per (surface, artifact_type, artifact_version).
/// Immutable once written — deduplicated on (merchant_surface_id, artifact_type, artifact_version).
/// Evidence rows in merchant_surfaces are never modified; artifacts are separate derived outputs.
///
/// artifact_type:    'parse_v1'
/// artifact_version: '1'
model merchant_surface_artifacts {
  id                  String   @id @default(uuid())
  merchantSurfaceId   String   @map("merchant_surface_id")
  artifactType        String   @map("artifact_type")
  artifactVersion     String   @map("artifact_version")
  artifactJson        Json     @map("artifact_json")
  createdAt           DateTime @default(now()) @map("created_at")

  merchant_surface merchant_surfaces @relation(fields: [merchantSurfaceId], references: [id], onDelete: Cascade)

  @@unique([merchantSurfaceId, artifactType, artifactVersion])
  @@index([merchantSurfaceId])
  @@index([artifactType, artifactVersion])
  @@index([createdAt])
  @@map("merchant_surface_artifacts")
}

/// Surface scan snapshots — append-only, one row per scan run per entity.
/// Current state is derived from the latest successful scan (http_status < 400).
/// Do not update rows in place; always insert new scan snapshots.
model merchant_surface_scans {
  id                     String   @id @default(cuid())
  entityId               String   @map("entity_id")
  fetchedAt              DateTime @default(now()) @map("fetched_at")
  sourceUrl              String   @map("source_url")
  finalUrl               String?  @map("final_url")
  httpStatus             Int?     @map("http_status")

  websitePlatform        String?  @map("website_platform")

  menuPresent            Boolean  @default(false) @map("menu_present")
  menuFormat             String?  @map("menu_format")   // html | pdf | external | none
  menuUrl                String?  @map("menu_url")
  menuReadState          String?  @map("menu_read_state") // readable | unreadable_pdf | inaccessible | none

  reservationPlatform    String?  @map("reservation_platform") // resy | opentable | tock | sevenrooms | none
  reservationUrl         String?  @map("reservation_url")

  orderingPlatform       String?  @map("ordering_platform") // toast | chownow | square | doordash | none
  orderingUrl            String?  @map("ordering_url")

  instagramPresent       Boolean  @default(false) @map("instagram_present")
  instagramUrl           String?  @map("instagram_url")

  newsletterPresent      Boolean  @default(false) @map("newsletter_present")
  newsletterPlatform     String?  @map("newsletter_platform") // mailchimp | klaviyo | substack | convertkit | unknown

  giftCardsPresent       Boolean  @default(false) @map("gift_cards_present")
  careersPresent         Boolean  @default(false) @map("careers_present")
  privateDiningPresent   Boolean  @default(false) @map("private_dining_present")

  siblingEntitiesPresent Boolean  @default(false) @map("sibling_entities_present")
  siblingEntityUrls      Json?    @map("sibling_entity_urls")   // String[]
  siblingEntityLabels    Json?    @map("sibling_entity_labels") // String[]

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([fetchedAt])
  @@map("merchant_surface_scans")
}

/// Merchant signals — current best per entity (upsert)
model merchant_signals {
  entityId               String   @id @map("entity_id")
  inferredCategory      String?  @map("inferred_category")
  inferredCuisine       Json?    @map("inferred_cuisine")
  reservationProvider   String?  @map("reservation_provider")
  reservationUrl        String?  @map("reservation_url")
  orderingProvider      String?  @map("ordering_provider")
  orderingUrl           String?  @map("ordering_url")
  menuUrl               String?  @map("menu_url")
  winelistUrl           String?  @map("winelist_url")
  socialLinks           Json?    @map("social_links")
  extractionConfidence  Decimal?  @map("extraction_confidence") @db.Decimal(4, 2)
  lastUpdatedAt         DateTime @default(now()) @updatedAt @map("last_updated_at")

  entities entities @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

/// Coverage sources — editorial references per entity (v2: full enrichment lifecycle)
/// Each row is a durable citation: fetched, archived, extracted, and made available
/// to every downstream interpretation tool. See coverage-source-enrichment-v1.md.
model coverage_sources {
  id                String                    @id @default(uuid())
  entityId          String                    @map("entity_id")
  url               String

  // ── Citation metadata ──────────────────────────────────────────────────
  sourceType        CoverageSourceType        @default(ARTICLE) @map("source_type")
  publicationName   String                    @map("publication_name")
  articleTitle      String?                   @map("article_title")
  author            String?
  publishedAt       DateTime?                 @map("published_at")

  // ── Archived content ───────────────────────────────────────────────────
  fetchedContent    String?                   @map("fetched_content")
  contentHash       String?                   @map("content_hash")
  wordCount         Int?                      @map("word_count")
  fetchedAt         DateTime?                 @map("fetched_at")

  // ── Link health ────────────────────────────────────────────────────────
  httpStatus        Int?                      @map("http_status")
  lastCheckedAt     DateTime?                 @map("last_checked_at")
  isAlive           Boolean                   @default(true) @map("is_alive")

  // ── Enrichment state ───────────────────────────────────────────────────
  enrichmentStage   CoverageEnrichmentStage   @default(INGESTED) @map("enrichment_stage")
  extractionVersion String?                   @map("extraction_version")
  extractedAt       DateTime?                 @map("extracted_at")

  // ── Timestamps ─────────────────────────────────────────────────────────
  createdAt         DateTime                  @default(now()) @map("created_at")

  // ── Relations ──────────────────────────────────────────────────────────
  entity       entities                       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  extractions  coverage_source_extractions[]

  @@unique([entityId, url])
  @@index([entityId])
  @@index([enrichmentStage])
  @@index([isAlive])
  @@index([entityId, sourceType])
  @@map("coverage_sources")
}

enum CoverageSourceType {
  ARTICLE
  REVIEW
  LIST
  VIDEO
  SOCIAL_POST
  GUIDE
}

enum CoverageEnrichmentStage {
  INGESTED
  FETCHED
  EXTRACTED
  FAILED
}

/// Coverage source extractions — structured data extracted from a coverage source by AI.
/// Bridge between fetched article content and the interpretation layer.
/// Versioned and re-runnable: when extraction prompts improve, re-run without touching
/// the source record. See coverage-source-enrichment-v1.md §2.
model coverage_source_extractions {
  id                  String    @id @default(uuid())
  coverageSourceId    String    @map("coverage_source_id")
  entityId            String    @map("entity_id")

  // ── Extraction metadata ────────────────────────────────────────────────
  extractionVersion   String    @map("extraction_version")
  extractedAt         DateTime  @default(now()) @map("extracted_at")
  isCurrent           Boolean   @default(true) @map("is_current")

  // ── Extracted signals (structured JSON) ────────────────────────────────
  // People: [{name, role, context, isPrimary?}]
  // Roles: chef, executive_chef, sous_chef, pastry_chef, sommelier,
  //        beverage_director, wine_director, bartender, general_manager,
  //        foh_director, foh_manager, owner, founder, partner, operator
  people              Json?

  // Food evidence: {cuisinePosture, cookingApproach[], dishes[], menuFormat[],
  //   specialtySignals: {sushi?, ramen?, taco?, pizza?, dumpling?}, rawMentions[]}
  // Feeds: food_program + specialty program assemblers, menu_identity, description gen
  foodEvidence        Json?     @map("food_evidence")

  // Beverage evidence: {wine: {listDepth?, naturalFocus?, byTheGlass?, sommelierMentioned?},
  //   cocktail: {programExists?, seasonal?, spiritFocus?},
  //   beer: {craftSelection?, tapList?}, nonAlcoholic: {zeroproof?, houseSodas?},
  //   coffeeTea: {specialtyProgram?, sourcing?}, rawMentions[]}
  // Feeds: wine_program, beer_program, cocktail_program, non_alcoholic_program, coffee_tea_program
  beverageEvidence    Json?     @map("beverage_evidence")

  // Service evidence: {serviceModel, reservationPosture, diningFormats[],
  //   privateDining: {mentioned?, roomDescribed?}, groupDining: {mentioned?, minHeadcount?},
  //   catering: {mentioned?, offSite?}, hospitalityNotes[], rawMentions[]}
  // Feeds: service_program, private_dining_program, group_dining_program, catering_program
  serviceEvidence     Json?     @map("service_evidence")

  // Atmosphere: {descriptors[], energyLevel, formality}
  // Feeds: derived signals (scene_energy, date_night_probability)
  atmosphereSignals   Json?     @map("atmosphere_signals")

  // Origin story: {type, narrative, foundingDate, backstory}
  // Feeds: description generation, identity enrichment
  originStory         Json?     @map("origin_story")

  // Accolades: [{name, source, year, type}] — awards, list inclusions, recognition
  accolades           Json?

  // Pull quotes: [{text, context}] — quotable sentences from the article
  pullQuotes          Json?     @map("pull_quotes")

  sentiment           String?   // POSITIVE, NEGATIVE, NEUTRAL, MIXED
  articleType         String?   @map("article_type")       // review, opening_coverage, list_inclusion, profile, news, closure_news
  relevanceScore      Float?    @map("relevance_score")    // 0.0–1.0

  // ── Relations ──────────────────────────────────────────────────────────
  coverageSource coverage_sources @relation(fields: [coverageSourceId], references: [id], onDelete: Cascade)
  entity         entities         @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([entityId, isCurrent])
  @@index([coverageSourceId])
  @@map("coverage_source_extractions")
}

