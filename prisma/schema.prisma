// ============================================================================
// ENTITY RESOLUTION SYSTEM
// New MDM (Master Data Management) tables for multi-source data integration
// ============================================================================

/// Raw records from all sources - never overwrite, always append
model raw_records {
  rawId           String @id @default(uuid()) @map("raw_id")

  // Source identification
  sourceName      String @map("source_name") // 'google_places', 'editorial_eater', 'editorial_infatuation', 'foursquare', 'saiko_ai', 'saiko_seed'
  externalId      String? @map("external_id") // ID from the source (e.g., Google Place ID)
  sourceUrl       String? @map("source_url") // Original article/page URL for editorial

  // Golden-first intake (Ken spec)
  intakeBatchId   String?   @map("intake_batch_id")
  sourceType      String?   @map("source_type") // e.g. 'editorial', 'csv', 'seed'
  importedAt      DateTime? @map("imported_at")

  // Standardized identifiers for blocking/matching
  placekey        String? // Placekey if available
  h3IndexR9       BigInt? @map("h3_index_r9") // H3 hexagon at resolution 9 (~0.1 km²)
  h3NeighborsR9   BigInt[] @map("h3_neighbors_r9") // K-ring neighbors for edge cases

  // The raw data
  rawJson         Json @map("raw_json") // Full blob exactly as received

  // Extracted fields for indexing (denormalized for query performance)
  nameNormalized  String? @map("name_normalized")
  lat             Decimal? @db.Decimal(10, 7)
  lng             Decimal? @db.Decimal(11, 7)

  // Metadata
  observedAt      DateTime? @map("observed_at")
  ingestedAt      DateTime  @default(now()) @map("ingested_at")
  isProcessed     Boolean   @default(false) @map("is_processed")

  // Relations
  resolution_links         resolution_links[]
  review_queue_a           review_queue[] @relation("ReviewQueueRecordA")
  review_queue_b           review_queue[] @relation("ReviewQueueRecordB")
  identity_enrichment_runs identity_enrichment_runs[]

  @@unique([sourceName, externalId])
  @@index([h3IndexR9])
  @@index([placekey])
  @@index([isProcessed])
  @@index([nameNormalized])
  @@index([intakeBatchId])
}

/// Entity links - maps raw records to canonical entities
// entity_links model removed — was FK to golden_records (dropped)

// golden_records model removed — replaced by canonical_entity_state + derived_signals (Fields v2)

/// Resolution links - audit trail for raw → golden resolution (Ken spec)
model resolution_links {
  id               String          @id @default(uuid())
  rawRecordId      String          @map("raw_record_id")
  goldenRecordId   String?         @map("golden_record_id") // null when resolution_type = ambiguous
  resolutionType   ResolutionType  @map("resolution_type")
  confidence       Float?
  matchMethod      MatchMethod     @map("match_method")
  resolverVersion  String?         @map("resolver_version")
  createdAt        DateTime        @default(now()) @map("created_at")

  raw_record    raw_records     @relation(fields: [rawRecordId], references: [rawId])

  @@index([rawRecordId])
  @@index([goldenRecordId])
  @@index([resolutionType])
}

/// Review queue - human-in-the-loop for ambiguous matches
model review_queue {
  queueId          String @id @default(uuid()) @map("queue_id")

  // What's being reviewed
  canonicalId      String?
  rawIdA           String @map("raw_id_a")
  rawIdB           String? @map("raw_id_b")

  // Conflict details
  conflictType     String @default("new_entity_review") @map("conflict_type") // 'low_confidence_match', 'attribute_mismatch', 'potential_duplicate', 'new_entity', 'new_entity_review'
  matchConfidence  Decimal? @db.Decimal(4, 3) @map("match_confidence")
  conflictingFields Json? @map("conflicting_fields")

  // Review workflow
  priority         Int     @default(5) // 1 (urgent) to 10 (low)
  status           String  @default("pending") // 'pending', 'in_progress', 'resolved', 'deferred', 'flagged'
  resolution       String? // 'merged', 'kept_separate', 'new_canonical', 'dismissed'
  resolutionNotes  String? @map("resolution_notes")

  // Pre-review machine enrichment state (new_entity_review only)
  // null on all low_confidence_match rows — gate only engages for new_entity_review
  identityEnrichmentStatus  String?  @map("identity_enrichment_status") // 'pending_enrichment' | 'enriching' | 'sufficient' | 'needs_review' | 'unresolved'
  identityAnchorCount       Int?     @map("identity_anchor_count")
  latestIdentityConfidence  Decimal? @map("latest_identity_confidence") @db.Decimal(4, 3)
  latestIdentityRunId       String?  @map("latest_identity_run_id") // soft ref → identity_enrichment_runs.id

  // Audit
  createdAt        DateTime  @default(now()) @map("created_at")
  assignedTo       String?   @map("assigned_to")
  resolvedBy       String?   @map("resolved_by")
  resolvedAt       DateTime? @map("resolved_at")

  // Relations
  raw_record_a       raw_records              @relation("ReviewQueueRecordA", fields: [rawIdA], references: [rawId])
  raw_record_b       raw_records?             @relation("ReviewQueueRecordB", fields: [rawIdB], references: [rawId])
  audit_logs         review_audit_log[]
  enrichment_runs    identity_enrichment_runs[]

  @@index([status])
  @@index([priority, status])
  @@index([canonicalId])
  @@index([identityEnrichmentStatus])
}

/// Identity enrichment runs — append-only lookup attempt history for new_entity_review cases.
/// One row per source per run. Never updated in place.
model identity_enrichment_runs {
  id                  String   @id @default(uuid())
  rawId               String   @map("raw_id")
  reviewQueueId       String?  @map("review_queue_id")

  // What was searched
  sourceName          String   @map("source_name")   // 'google_candidate_search' | 'gpid_detection' | 'website_discovery' | 'instagram_discovery' | 'corroboration'
  searchedName        String?  @map("searched_name")
  searchedCity        String?  @map("searched_city")

  // What was found
  resultJson          Json     @map("result_json")    // raw candidates / signals from this step

  // Computed outcome of this step
  identityConfidence  Decimal? @map("identity_confidence") @db.Decimal(4, 3)
  anchorCount         Int      @default(0) @map("anchor_count")
  decisionStatus      String   @map("decision_status") // 'sufficient' | 'needs_review' | 'unresolved'

  createdAt           DateTime @default(now()) @map("created_at")

  review_queue        review_queue? @relation(fields: [reviewQueueId], references: [queueId])
  raw_record          raw_records   @relation(fields: [rawId], references: [rawId])

  @@index([rawId])
  @@index([reviewQueueId])
  @@index([decisionStatus])
  @@index([createdAt])
  @@map("identity_enrichment_runs")
}

/// Audit trail for review decisions
model review_audit_log {
  logId            String   @id @default(uuid()) @map("log_id")
  queueId          String   @map("queue_id")
  resolvedBy       String   @map("resolved_by")
  resolution       String
  decisionTimeMs   Int?     @map("decision_time_ms")
  resolvedAt       DateTime @default(now()) @map("resolved_at")

  // Relations
  review_queue review_queue @relation(fields: [queueId], references: [queueId])

  @@index([queueId])
  @@index([resolvedAt])
}

