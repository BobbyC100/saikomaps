/// Operator → Place link candidates (human review). Idempotent on (actor_id, candidate_url) or (actor_id, candidate_name, candidate_address).
enum OperatorPlaceCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  STALE
}

enum ConfidenceBucket {
  HIGH
  MEDIUM
  LOW
}

model OperatorPlaceCandidate {
  id                String                        @id @default(uuid())
  actorId           String                        @map("actor_id")
  entityId          String?                       @map("entity_id")
  candidateName     String                        @map("candidate_name")
  candidateUrl      String?                       @map("candidate_url")
  candidateAddress  String?                       @map("candidate_address")
  sourceUrl         String                        @map("source_url")
  matchScore        Float                         @default(0) @map("match_score")
  matchReason       String?                       @map("match_reason")
  status            OperatorPlaceCandidateStatus @default(PENDING)
  rejectionReason   String?                       @map("rejection_reason")
  reviewedAt        DateTime?                     @map("reviewed_at")
  approvedBy        String?                       @map("approved_by")
  confidenceBucket  ConfidenceBucket?             @map("confidence_bucket")
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  actor  Actor     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  entity entities? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([actorId, status])
  @@index([entityId])
  @@map("operator_place_candidates")
}

/// Entity-Actor relationships (Saiko Trace)
/// Canonical view for the map_places dataset. Do not use for app-facing Place UI.
model EntityActorRelationship {
  id         String    @id @default(uuid())
  entityId   String    @map("entity_id")
  actorId    String    @map("actor_id")
  role       ActorRole
  confidence Float?
  source     String?
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)
  actor  Actor          @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([actorId])
}

/// Place-Actor relationships — app-facing projection layer.
/// Materialized when place ↔ golden exists; temporary canonical when place has no golden.
/// Written only by ingestion/sync logic. UI reads from here.
///
/// Note: @@unique([placeId, actorId, role]) prevents duplicate rows but does NOT enforce
/// "at most one isPrimary=true per (place, role)". Later consider a partial unique index
/// e.g. UNIQUE (place_id) WHERE is_primary AND role = 'operator'.
model PlaceActorRelationship {
  id         String    @id @default(cuid())
  entityId   String    @map("entity_id")
  actorId    String    @map("actor_id")
  role       ActorRole
  isPrimary  Boolean   @default(false) @map("is_primary")
  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  sources    Json?
  confidence Float?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)
  actor  Actor    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([entityId, actorId, role])
  @@index([entityId])
  @@index([actorId])
  @@map("place_actor_relationships")
}

/// Spatial containment relationships (park → facility, zone → place, etc.)
/// Deliberately separate from EntityActorRelationship (different domain).
model ParkFacilityRelationship {
  id                String                  @id @default(uuid())
  parentEntityId    String                  @map("parent_entity_id")
  childEntityId     String                  @map("child_entity_id")
  relationshipType  SpatialRelationshipType @default(CONTAINS) @map("relationship_type")
  confidence        Float?
  source            String                  @default("auto_match")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  parentEntity entities @relation("park_parent", fields: [parentEntityId], references: [id], onDelete: Cascade)
  childEntity  entities @relation("park_child", fields: [childEntityId], references: [id], onDelete: Cascade)

  @@unique([parentEntityId, childEntityId, relationshipType])
  @@index([parentEntityId])
  @@index([childEntityId])
  @@map("park_facility_relationships")
}

enum SpatialRelationshipType {
  CONTAINS
  ZONE_OF
  PART_OF
  ADJACENT_TO
}

/// Fields membership - entities in the curated index (Saiko Fields)
model FieldsMembership {
  id         String    @id @default(uuid())
  entityId   String    @map("entity_id")
  includedAt DateTime  @map("included_at")
  removedAt  DateTime? @map("removed_at")
  curatorId  String?   @map("curator_id")
  reason     String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

/// Trace signals cache - one row per entity, latest only (Saiko Trace)
model TraceSignalsCache {
  id         String   @id @default(uuid())
  entityId   String   @unique @map("entity_id")
  computedAt DateTime @map("computed_at")
  signals    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
}

// ============================================================================
// COVERAGE RUN LEDGER
// Idempotency + dedupe for coverage enrichment pipeline
// ============================================================================

/// coverage_runs — metadata for each coverage audit/run
model coverage_runs {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  dbHost    String   @map("db_host")
  dbName    String   @map("db_name")
  gitSha    String?  @map("git_sha")
  limitVal  Int?     @map("limit_val")
  laOnly    Boolean  @default(true) @map("la_only")
  ttlDays   Int?     @map("ttl_days")

  @@map("coverage_runs")
}

// ============================================================================
// GPID RESOLUTION QUEUE (Identity Queue v1)
// Human-in-the-loop for unresolved Google Place ID matches
// Extensible: later add enrichment_queue, data_completion_queue as separate queue types
// ============================================================================

enum GpidResolverStatus {
  MATCH
  AMBIGUOUS
  NO_MATCH
  ERROR
}

enum GpidHumanStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
}

enum GpidHumanDecision {
  APPLY_GPID
  MARK_NO_MATCH
  MARK_AMBIGUOUS
}

model gpid_resolution_queue {
  id                 String            @id @default(uuid())
  entityId           String            @map("entity_id")
  candidateGpid      String?           @map("candidate_gpid") // best single candidate (for MATCH)
  resolverStatus     GpidResolverStatus @map("resolver_status")
  reasonCode         String?           @map("reason_code") // TEXT_LOW_SIM, TEXT_MULTI_RESULTS, etc.
  similarityScore    Float?            @map("similarity_score") // 0-100
  candidatesJson     Json?             @map("candidates_json") // all candidates + meta
  sourceRunId        String?           @map("source_run_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  // Human review
  humanStatus        GpidHumanStatus    @default(PENDING) @map("human_status")
  humanDecision      GpidHumanDecision? @map("human_decision")
  humanNote          String?            @map("human_note")
  reviewedBy         String?            @map("reviewed_by")
  reviewedAt         DateTime?          @map("reviewed_at")

  entities           entities          @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([humanStatus])
  @@index([resolverStatus])
  @@index([entityId])
  @@index([reasonCode])
  @@map("gpid_resolution_queue")
}

/// place_coverage_status — per-dedupe_key coverage state (no double spend)
model place_coverage_status {
  id                  String   @id @default(cuid())
  entityId            String   @map("entity_id")
  dedupeKey           String   @unique @map("dedupe_key") // google_place_id or entity_id
  lastSuccessAt       DateTime? @map("last_success_at")
  lastAttemptAt       DateTime? @map("last_attempt_at")
  lastAttemptStatus   String?  @map("last_attempt_status") // SUCCESS | FAIL | RUNNING
  lastErrorCode       String?  @map("last_error_code")
  lastErrorMessage    String?  @map("last_error_message")
  lastMissingGroups   Json?    @map("last_missing_groups") // string[]
  source              String?  // GOOGLE_PLACES | SCRAPE | MANUAL
  updatedAt           DateTime @updatedAt @map("updated_at")

  entities entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([lastAttemptStatus])
  @@map("place_coverage_status")
}

// ============================================================================
// PLACE JOB LOG — cost/metric audit (identity, operator_link, scan jobs)
// No UI. Minimal fields for pages_fetched, ai_calls, duration_ms, estimated_cost.
// ============================================================================

model place_job_log {
  id              String   @id @default(uuid())
  entityId        String   @map("entity_id")
  entityType      String   @map("entity_type") // 'place' | 'actor' | 'golden_record' | 'batch'
  jobType         String   @map("job_type")    // 'IDENTITY' | 'OPERATOR_LINK' | 'SCAN'
  pagesFetched    Int      @default(0) @map("pages_fetched")
  aiCalls         Int      @default(0) @map("ai_calls")
  durationMs      Int?     @map("duration_ms")
  estimatedCost   Decimal? @map("estimated_cost") @db.Decimal(10, 6)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityId])
  @@index([jobType])
  @@index([createdAt])
  @@map("place_job_log")
}

// ============================================================================
// FIELDS V2 — CLEAN DATA LAYER
// Three-layer model: Observed Claims → Canonical Entity State → Derived/Interpretation
// ============================================================================

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SourceType {
  GOOGLE_PLACES
  EDITORIAL
  OPERATOR_WEBSITE
  SOCIAL
  NEWSLETTER
  HUMAN_REVIEW
  SYSTEM_IMPORT
}

enum AttributeClass {
  CANONICAL
  DERIVED
  INTERPRETATION
}

enum DecayPolicy {
  NONE
  TIME_BASED
  SOURCE_UPDATED
}

enum ExtractionMethod {
  API
  SCRAPE
  AI_EXTRACT
  HUMAN
  IMPORT
}

/// How the claim was matched to an entity at intake time.
enum ClaimResolutionMethod {
  SLUG_EXACT
  GOOGLE_PLACE_ID_EXACT
  PLACEKEY_EXACT
  FUZZY_MATCH
  HUMAN_REVIEW
  NEW_ENTITY
}

enum SanctionMethod {
  AUTO_HIGH_CONFIDENCE
  AUTO_SOLE_SOURCE
  HUMAN_APPROVED
  HUMAN_OVERRIDE
}

enum SanctionConflictStatus {
  OPEN
  RESOLVED_HUMAN
  RESOLVED_AUTO
}

enum InterpretationType {
  TAGLINE
  PULL_QUOTE
  SCENESENSE_PRL
  VOICE_DESCRIPTOR
  TIMEFOLD
}

// ---------------------------------------------------------------------------
// A. Source Registry
// Trust-gated catalog of every data source the system can accept.
// Replaces `sources`. All observed claims must have a valid source_id here.
// ---------------------------------------------------------------------------

model source_registry {
  id                      String     @id // machine key: "google_places", "eater_la"
  displayName             String     @map("display_name")
  sourceType              SourceType @map("source_type")
  trustTier               Int        @map("trust_tier") // 1 = highest, 5 = lowest
  requiresHumanApproval   Boolean    @default(false) @map("requires_human_approval")
  baseDomain              String?    @map("base_domain")
  isActive                Boolean    @default(true) @map("is_active")
  createdAt               DateTime   @default(now()) @map("created_at")

  claims observed_claims[]

  @@map("source_registry")
  @@index([trustTier])
  @@index([isActive])
}

// ---------------------------------------------------------------------------
// B. Attribute Registry
// Classifies every attribute key the system tracks.
// attribute_class drives which table stores the value.
// ---------------------------------------------------------------------------

model attribute_registry {
  attributeKey        String         @id @map("attribute_key")
  displayName         String         @map("display_name")
  attributeClass      AttributeClass @map("attribute_class")
  identityCritical    Boolean        @default(false) @map("identity_critical")
  sanctionThreshold   Decimal        @default(0.70) @db.Decimal(3, 2) @map("sanction_threshold")
  decayPolicy         DecayPolicy    @default(NONE) @map("decay_policy")

  claims observed_claims[]

  @@map("attribute_registry")
}

// ---------------------------------------------------------------------------
// C. Observed Claims
// Immutable source observations. One row per (entity, attribute, source, time).
// Never updated — superseded via supersedes_claim_id chain.
// ---------------------------------------------------------------------------

model observed_claims {
  claimId             String               @id @default(uuid()) @map("claim_id")
  entityId            String               @map("entity_id")
  attributeKey        String               @map("attribute_key")
  rawValue            Json                 @map("raw_value")
  normalizedValue     String?              @map("normalized_value")
  sourceId            String               @map("source_id")
  sourceUrl           String?              @map("source_url")
  observedAt          DateTime             @map("observed_at")
  extractedAt         DateTime             @default(now()) @map("extracted_at")
  extractionMethod    ExtractionMethod     @map("extraction_method")
  confidence          Decimal?             @db.Decimal(4, 3) @map("confidence")
  resolutionMethod    ClaimResolutionMethod @map("resolution_method")
  resolutionConfidence Decimal?             @db.Decimal(4, 3) @map("resolution_confidence")
  supersedesClaimId   String?              @map("supersedes_claim_id")
  isActive            Boolean              @default(true) @map("is_active")

  entity          entities          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  source          source_registry   @relation(fields: [sourceId], references: [id])
  attribute       attribute_registry @relation(fields: [attributeKey], references: [attributeKey])
  supersedes      observed_claims?  @relation("Supersession", fields: [supersedesClaimId], references: [claimId])
  superseded_by   observed_claims[] @relation("Supersession")
  sanctions       canonical_sanctions[]

  @@map("observed_claims")
  @@index([entityId, attributeKey])
  @@index([entityId, isActive])
  @@index([sourceId])
  @@index([extractedAt])
}

// ---------------------------------------------------------------------------
// D. Canonical Entity State
// The system's currently sanctioned belief about an entity.
// One row per entity. All values must be backed by a canonical_sanctions row.
// Canonical entity state — the fields the product actually needs.
// ---------------------------------------------------------------------------

model canonical_entity_state {
  entityId          String @id @map("entity_id")

  // Identity-critical (sanction_threshold 0.95)
  name              String
  googlePlaceId     String? @unique @map("google_place_id")
  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(11, 7)

  // Operational (sanction_threshold 0.80)
  address           String?
  neighborhood      String?
  phone             String?
  website           String?
  instagram         String?
  tiktok            String?
  hoursJson         Json?    @map("hours_json")
  priceLevel        Int?     @map("price_level")
  reservationUrl    String?  @map("reservation_url")
  menuUrl           String?  @map("menu_url")
  winelistUrl       String?  @map("winelist_url")

  // Events / hospitality programs (sanction_threshold 0.70)
  eventsUrl         String? @map("events_url")
  cateringUrl       String? @map("catering_url")
  eventInquiryEmail String? @map("event_inquiry_email")
  eventInquiryFormUrl String? @map("event_inquiry_form_url")

  // Content (requires explicit sanction or human approval)
  description       String?
  cuisineType       String? @map("cuisine_type")
  category          String?
  tips              String[] @default([])

  // Google Photos blob (observed from Google API, surfaced here for convenience)
  googlePhotos      Json? @map("google_photos")
  googlePlacesAttributes Json? @map("google_places_attributes")

  // Sanctioning metadata
  lastSanctionedAt  DateTime? @map("last_sanctioned_at")
  sanctionedBy      String?   @map("sanctioned_by") // "SYSTEM" or user_id

  entity    entities              @relation(fields: [entityId], references: [id], onDelete: Cascade)
  sanctions canonical_sanctions[]

  @@map("canonical_entity_state")
  @@index([googlePlaceId])
  @@index([neighborhood])
}

// ---------------------------------------------------------------------------
// F. Canonical Sanctions
// Audit trail: which observed_claim currently backs which canonical field.
// One "current" row per (entity_id, attribute_key).
// Partial unique index enforced via raw SQL: CREATE UNIQUE INDEX ON
// canonical_sanctions (entity_id, attribute_key) WHERE is_current = true;
// ---------------------------------------------------------------------------

model canonical_sanctions {
  sanctionId      String         @id @default(uuid()) @map("sanction_id")
  entityId        String         @map("entity_id")
  attributeKey    String         @map("attribute_key")
  claimId         String         @map("claim_id")
  sanctionedAt    DateTime       @default(now()) @map("sanctioned_at")
  sanctionedBy    String         @map("sanctioned_by") // "SYSTEM" or user_id
  sanctionMethod  SanctionMethod @map("sanction_method")
  isCurrent       Boolean        @default(true) @map("is_current")

  claim          observed_claims        @relation(fields: [claimId], references: [claimId])
  entity_state   canonical_entity_state @relation(fields: [entityId], references: [entityId], onDelete: Cascade)

  @@map("canonical_sanctions")
  @@index([entityId, attributeKey])
  @@index([claimId])
  @@index([entityId, attributeKey, isCurrent])
}

// ---------------------------------------------------------------------------
// G. Sanction Conflicts
// Created when sanctioning function cannot auto-resolve competing claims.
// Human resolves by picking the winning claim_id.
// ---------------------------------------------------------------------------

model sanction_conflicts {
  conflictId        String                 @id @default(uuid()) @map("conflict_id")
  entityId          String                 @map("entity_id")
  attributeKey      String                 @map("attribute_key")
  claimIds          String[]               @map("claim_ids")
  conflictReason    String                 @map("conflict_reason")
  status            SanctionConflictStatus @default(OPEN)
  resolvedClaimId   String?                @map("resolved_claim_id")
  resolvedBy        String?                @map("resolved_by")
  resolvedAt        DateTime?              @map("resolved_at")
  createdAt         DateTime               @default(now()) @map("created_at")

  @@map("sanction_conflicts")
  @@index([entityId, status])
  @@index([attributeKey, status])
  @@index([status])
}

// ---------------------------------------------------------------------------
// H. Derived Signals
// Computed outputs from claims and/or canonical state. Never canonical.
// Versioned so recompute is safe.
// energy_scores and place_tag_scores remain separate (already correct layer).
// ---------------------------------------------------------------------------

model derived_signals {
  signalId        String   @id @default(uuid()) @map("signal_id")
  entityId        String   @map("entity_id")
  signalKey       String   @map("signal_key")
  signalValue     Json     @map("signal_value")
  signalVersion   String   @map("signal_version")
  inputClaimIds   String[] @map("input_claim_ids")
  computedAt      DateTime @default(now()) @map("computed_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("derived_signals")
  @@unique([entityId, signalKey, signalVersion])
  @@index([entityId])
  @@index([signalKey])
}

// ---------------------------------------------------------------------------
// I. Interpretation Cache
// Taglines, pull quotes, SceneSense outputs. Never canonical. Versioned + expirable.
// content shape per type:
//   TAGLINE: { text: string }
//   PULL_QUOTE: { text: string, author: string|null, source_name: string|null, source_url: string|null }
//   SCENESENSE_PRL: { prl: number, atmosphere: string[], ambiance: string[], scene: string[] }
//   VOICE_DESCRIPTOR: { text: string }
//   TIMEFOLD: { class: 'STABILITY' | 'NEWNESS', phrase: string, proposed_by: 'system', approved_by: string | null }
// ---------------------------------------------------------------------------

model interpretation_cache {
  cacheId          String             @id @default(uuid()) @map("cache_id")
  entityId         String             @map("entity_id")
  outputType       InterpretationType @map("output_type")
  content          Json               @map("content")
  promptVersion    String             @map("prompt_version")
  modelVersion     String?            @map("model_version")
  generatedAt      DateTime           @default(now()) @map("generated_at")
  expiresAt        DateTime?          @map("expires_at")
  inputSignalIds   String[]           @map("input_signal_ids")
  isCurrent        Boolean            @default(true) @map("is_current")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("interpretation_cache")
  @@unique([entityId, outputType, promptVersion])
  @@index([entityId])
  @@index([entityId, outputType, isCurrent])
}

// =============================================================================
// Instagram Ingestion (v1)
// =============================================================================

/// One row per connected Instagram account. Mutable — overwrite on each fetch.
/// Linked to entities via entity_id FK.
model instagram_accounts {
  id                       String    @id @default(uuid())
  entityId                 String    @map("entity_id")
  instagramUserId          String    @unique @map("instagram_user_id")
  username                 String
  accountType              String?   @map("account_type")     // BUSINESS | CREATOR | PERSONAL
  mediaCount               Int?      @map("media_count")
  canonicalInstagramUrl    String?   @map("canonical_instagram_url")
  lastFetchedAt            DateTime? @map("last_fetched_at")
  lastSuccessfulFetchAt    DateTime? @map("last_successful_fetch_at")
  sourceStatus             String    @default("active") @map("source_status") // active | revoked | error
  rawPayload               Json?     @map("raw_payload")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)
  media  instagram_media[]

  @@index([entityId])
  @@index([username])
  @@map("instagram_accounts")
}

/// One row per Instagram post/media object. Upsert by instagram_media_id.
/// timestamp (original post time) is immutable; mutable fields refreshed on re-fetch.
model instagram_media {
  id                 String   @id @default(uuid())
  instagramMediaId   String   @unique @map("instagram_media_id")
  instagramUserId    String   @map("instagram_user_id")
  mediaType          String   @map("media_type")        // IMAGE | VIDEO | CAROUSEL_ALBUM
  mediaUrl           String?  @map("media_url")          // CDN URL (expires)
  thumbnailUrl       String?  @map("thumbnail_url")      // for VIDEO type
  permalink          String   @map("permalink")           // permanent IG URL
  caption            String?
  timestamp          DateTime                             // original post time (immutable)
  fetchedAt          DateTime @default(now()) @map("fetched_at")
  photoType          String?  @map("photo_type")         // INTERIOR | FOOD | BAR_DRINKS | CROWD_ENERGY | DETAIL | EXTERIOR (from vision classification)
  classifiedAt       DateTime? @map("classified_at")      // When this photo was classified by Claude Haiku
  rawPayload         Json?    @map("raw_payload")

  account instagram_accounts @relation(fields: [instagramUserId], references: [instagramUserId], onDelete: Cascade)

  @@index([instagramUserId])
  @@index([timestamp])
  @@index([instagramUserId, timestamp])
  @@index([photoType])
  @@map("instagram_media")
}

/// Append-only insight snapshots. One row per metric observation.
/// Never update or overwrite existing rows.
model instagram_insight_snapshots {
  id           String   @id @default(uuid())
  subjectType  String   @map("subject_type")   // 'account' | 'media'
  subjectId    String   @map("subject_id")     // instagram_user_id or instagram_media_id
  metricName   String   @map("metric_name")    // impressions | reach | engagement
  metricValue  Decimal  @map("metric_value") @db.Decimal(12, 2)
  observedAt   DateTime @default(now()) @map("observed_at")
  windowLabel  String?  @map("window_label")   // day | week | days_28 | lifetime
  rawPayload   Json?    @map("raw_payload")

  @@index([subjectType, subjectId])
  @@index([subjectId, metricName, observedAt])
  @@index([observedAt])
  @@map("instagram_insight_snapshots")
}

// ---------------------------------------------------------------------------
// Entity Issues — Coverage Operations unified operational layer
// One row per (entity_id, issue_type). Represents an actionable problem.
// Generated by the issue scanner, resolved by resolution tools or human action.
// See docs/architecture/coverage-ops-approach-v1.md (COVOPS-APPROACH-V1).
// ---------------------------------------------------------------------------

model entity_issues {
  id               String    @id @default(uuid())
  entityId         String    @map("entity_id")
  problemClass     String    @map("problem_class")     // identity | location | contact | social | editorial
  issueType        String    @map("issue_type")        // unresolved_identity | missing_neighborhood | etc.
  status           String    @default("open")           // open | needs_automation | processing | needs_human | resolved | suppressed
  severity         String    @default("medium")         // critical | high | medium | low
  blockingPublish  Boolean   @default(false) @map("blocking_publish")
  recommendedTool  String?   @map("recommended_tool")  // derive_neighborhood | enrich_stage | instagram_discover | gpid_resolution
  detail           Json?                                // arbitrary context: { missing_fields, enrichment_stage, etc. }
  resolvedAt       DateTime? @map("resolved_at")
  resolvedBy       String?   @map("resolved_by")       // SYSTEM | SCANNER | user_id
  suppressedReason String?  @map("suppressed_reason")  // confirmed_none | not_applicable | wont_fix
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, issueType])
  @@index([status])
  @@index([problemClass, status])
  @@index([issueType, status])
  @@index([severity, status])
  @@map("entity_issues")
}

// ---------------------------------------------------------------------------
// Reservation Provider Matches — Validation layer for reservation providers
// One row per (entity_id, provider). Stores match quality, confidence,
// and provider-specific program signals. Additive on top of merchant_signals
// extraction; does not replace existing reservation_url flow.
// See docs/reservation-v1-architecture-review.md.
// ---------------------------------------------------------------------------

model reservation_provider_matches {
  id                String    @id @default(uuid())
  entityId          String    @map("entity_id")
  provider          String                          // opentable | resy | tock | sevenrooms | yelp
  providerVenueId   String?   @map("provider_venue_id")
  bookingUrl        String?   @map("booking_url")

  matchStatus       String    @default("unverified") @map("match_status") // matched | probable | ambiguous | no_match | unverified
  matchScore        Float?    @map("match_score")     // 0.0–1.0 composite quality
  matchSignals      Json?     @map("match_signals")   // { name_similarity, address_match, phone_match, domain_match, geo_proximity }

  validationSource  String    @map("validation_source") // website_link | widget_metadata | manual | directory_api
  confidenceLevel   String    @default("weak") @map("confidence_level") // weak | strong_merchant | provider_verified

  isRenderable      Boolean   @default(false) @map("is_renderable") // derived: match_status + confidence + booking_url
  programSignals    Json?     @map("program_signals")   // provider-specific: { has_widget, has_notify, has_events, ... }

  lastCheckedAt     DateTime  @default(now()) @map("last_checked_at")
  lastVerifiedAt    DateTime? @map("last_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  entity entities @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, provider])
  @@index([entityId])
  @@index([provider, matchStatus])
  @@index([provider, isRenderable])
  @@index([matchStatus, lastCheckedAt])
  @@map("reservation_provider_matches")
}
