# Copy to .env.local and fill in values.
# Required for config/db (v3.0) — scripts using purpose-based connections.

# Neon pooled connection (host contains -pooler)
DATABASE_URL_POOLED=postgresql://user:pass@ep-xxx-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon direct connection (host does NOT contain -pooler)
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

DB_ENV=local_dev
